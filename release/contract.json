{
  "version": 3,
  "packageName": "@labpics/icons",
  "primary": {
    "kind": "npm",
    "access": "public",
    "install": "pnpm add @labpics/icons"
  },
  "fallback": {
    "kind": "github-dist-tag",
    "specifier": "github:Labpics-Team/lab-icons#vX.Y.Z-dist",
    "immutable": true
  },
  "files": [
    "dist/index.d.ts",
    "dist/index.js",
    "dist/ir/index.d.ts",
    "dist/ir/index.js",
    "dist/ir/recipes.d.ts",
    "dist/ir/recipes.js"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./ir": {
      "types": "./dist/ir/index.d.ts",
      "import": "./dist/ir/index.js"
    },
    "./ir/recipes": {
      "types": "./dist/ir/recipes.d.ts",
      "import": "./dist/ir/recipes.js"
    }
  }
}
