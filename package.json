{
  "name": "@labpics/icons",
  "version": "0.3.0",
  "private": false,
  "description": "Labpics icon library — 444 SVG (Filled + Outline), tree-shakeable ESM",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Labpics-Team/lab-icons.git"
  },
  "publishConfig": {
    "access": "public"
  },
  "type": "module",
  "packageManager": "pnpm@11.13.1",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./ir": {
      "types": "./dist/ir/index.d.ts",
      "import": "./dist/ir/index.js"
    },
    "./ir/recipes": {
      "types": "./dist/ir/recipes.d.ts",
      "import": "./dist/ir/recipes.js"
    }
  },
  "sideEffects": false,
  "files": [
    "dist/index.d.ts",
    "dist/index.js",
    "dist/ir/catalog.generated.d.ts",
    "dist/ir/index.d.ts",
    "dist/ir/index.js",
    "dist/ir/recipes.d.ts",
    "dist/ir/recipes.js"
  ],
  "scripts": {
    "build": "pnpm build:static && pnpm build:catalog && pnpm build:ir",
    "build:static": "node scripts/build.js && node scripts/build-anatomy.js",
    "build:ir": "node scripts/build-ir.mjs",
    "build:anatomy": "node scripts/build-anatomy.js",
    "build:catalog": "node scripts/build-catalog.mjs",
    "observatory": "node scripts/build-observatory.mjs",
    "typecheck": "tsc --noEmit",
    "check:security": "pnpm audit --audit-level=low",
    "check:publint": "publint --strict",
    "check:attw": "attw --pack . --profile esm-only --format table --no-emoji --no-color",
    "check:repo-contract": "node scripts/check-repo-contract.js",
    "check:package-artifact": "node scripts/check-package-artifact.js",
    "check:package-size": "node scripts/check-package-size.js",
    "check:parity": "node scripts/check-parity.js",
    "check:colors": "node scripts/check-colors.js",
    "check:treeshake": "node scripts/check-treeshake.js",
    "check:variant-parity": "node scripts/check-variant-parity.js",
    "check:anatomy": "node scripts/check-anatomy.js && node scripts/check-anatomy-drift.js",
    "check:catalog": "node scripts/check-catalog.js",
    "check:anatomy:drift": "node scripts/check-anatomy-drift.js",
    "check:path-quality": "node scripts/check-path-quality.js",
    "check:static-grid": "node scripts/check-static-grid.js",
    "check:fill-rule": "node scripts/check-fill-rule.js",
    "check:topology": "node scripts/check-topology.js",
    "check:corners": "node scripts/check-corners.js",
    "check:adjacency": "node scripts/check-adjacency.js",
    "check:ink-weight": "node scripts/check-ink-weight.js",
    "check:ink-weight:axes": "node scripts/check-ink-weight.js --axes",
    "check:grammar": "node scripts/check-grammar.js",
    "check:anim-ready": "node scripts/check-anim-ready.js",
    "check:fidelity": "node scripts/check-fidelity.js",
    "check:dry-coverage": "node scripts/check-dry-coverage.js",
    "check:docs-drift": "node scripts/check-docs-drift.js",
    "prepack": "pnpm build",
    "test": "vitest run",
    "verify": "node scripts/check-repo-contract.js && node scripts/check-catalog.js && pnpm check:security && tsc --noEmit && pnpm build && node scripts/check-package-size.js && node scripts/check-package-artifact.js && pnpm check:publint && pnpm check:attw && node scripts/check-parity.js && node scripts/check-colors.js && node scripts/check-treeshake.js && node scripts/check-variant-parity.js && node scripts/check-anatomy.js && node scripts/check-anatomy-drift.js && node scripts/check-path-quality.js && node scripts/check-static-grid.js && node scripts/check-fill-rule.js && node scripts/check-topology.js && node scripts/check-corners.js && node scripts/check-adjacency.js && node scripts/check-ink-weight.js && node scripts/check-ink-weight.js --axes && node scripts/check-grammar.js && node scripts/check-fidelity.js && node scripts/check-dry-coverage.js && node scripts/check-anim-ready.js && node scripts/check-docs-drift.js && vitest run"
  },
  "devDependencies": {
    "@arethetypeswrong/cli": "0.18.5",
    "esbuild": "0.28.1",
    "fflate": "0.8.3",
    "publint": "0.3.21",
    "rollup": "4.62.2",
    "svgo": "4.0.2",
    "typescript": "7.0.2",
    "vite": "8.1.4",
    "vitest": "4.1.10"
  },
  "license": "MIT",
  "keywords": [
    "icons",
    "svg",
    "design-system",
    "labpics",
    "outline",
    "filled"
  ],
  "engines": {
    "node": ">=22.14.0",
    "pnpm": ">=11.13.1"
  }
}
