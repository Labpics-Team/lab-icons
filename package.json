{
  "name": "@labpics/icons",
  "version": "0.0.1",
  "private": true,
  "description": "Labpics icon library — 444 SVG (Filled + Outline), tree-shakeable ESM",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./animate": {
      "types": "./dist/animate/index.d.ts",
      "import": "./dist/animate/index.js",
      "require": "./dist/animate/index.cjs"
    }
  },
  "sideEffects": false,
  "scripts": {
    "build": "node scripts/build.js",
    "build:animate": "tsup",
    "typecheck": "tsc --noEmit",
    "check:parity": "node scripts/check-parity.js",
    "check:colors": "node scripts/check-colors.js",
    "check:treeshake": "node scripts/check-treeshake.js",
    "check:semantics": "node scripts/check-semantics.js",
    "check:choreographies": "node scripts/check-choreographies.js",
    "check:layers": "node scripts/check-layers.js",
    "check:motion-bounds": "node scripts/check-motion-bounds.js",
    "check:motion-collision": "node scripts/check-motion-collision.js",
    "check:variant-parity": "node scripts/check-variant-parity.js",
    "check:anatomy": "node scripts/check-anatomy.js",
    "test": "vitest run",
    "verify": "node scripts/build.js && tsup && tsc --noEmit && node scripts/check-parity.js && node scripts/check-colors.js && node scripts/check-treeshake.js && node scripts/check-semantics.js && node scripts/check-choreographies.js && node scripts/check-layers.js && node scripts/check-motion-bounds.js && node scripts/check-motion-collision.js && node scripts/check-variant-parity.js && node scripts/check-anatomy.js && vitest run"
  },
  "devDependencies": {
    "rollup": "^4.24.0",
    "svgo": "^3.3.2",
    "tsup": "8.3.6",
    "typescript": "5.7.3",
    "vitest": "2.1.8"
  }
}
