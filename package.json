{
    "name":  "@labpics/icons",
    "version":  "0.0.1",
    "private":  true,
    "description":  "Labpics icon library вЂ” 444 SVG (Filled + Outline), tree-shakeable ESM",
    "type":  "module",
    "main":  "./dist/index.js",
    "module":  "./dist/index.js",
    "types":  "./dist/index.d.ts",
    "exports":  {
                    ".":  {
                              "import":  "./dist/index.js",
                              "types":  "./dist/index.d.ts"
                          }
                },
    "sideEffects":  false,
    "scripts":  {
                    "build":  "node scripts/build.js",
                    "check:parity":  "node scripts/check-parity.js",
                    "check:colors":  "node scripts/check-colors.js",
                    "check:treeshake":  "node scripts/check-treeshake.js",
                    "verify":  "node scripts/build.js \u0026\u0026 node scripts/check-parity.js \u0026\u0026 node scripts/check-colors.js \u0026\u0026 node scripts/check-treeshake.js \u0026\u0026 vitest run",
                    "test":  "vitest run"
                },
    "devDependencies":  {
                            "rollup":  "^4.24.0",
                            "svgo":  "^3.3.2",
                            "vitest":  "2.1.8"
                        }
}
