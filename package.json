{
  "name": "@labpics/icons",
  "version": "0.2.0",
  "private": false,
  "description": "Labpics icon library — 444 SVG (Filled + Outline), tree-shakeable ESM",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Labpics-Team/lab-icons.git"
  },
  "type": "module",
  "packageManager": "pnpm@10.30.3",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./animate": {
      "types": "./dist/animate/index.d.ts",
      "import": "./dist/animate/index.js",
      "require": "./dist/animate/index.cjs"
    }
  },
  "sideEffects": false,
  "files": [
    "dist/index.js",
    "dist/index.d.ts",
    "dist/animate"
  ],
  "scripts": {
    "build": "node scripts/build.js && node scripts/build-anatomy.js",
    "build:animate": "tsup",
    "build:anatomy": "node scripts/build-anatomy.js",
    "typecheck": "tsc --noEmit",
    "check:repo-contract": "node scripts/check-repo-contract.js",
    "check:parity": "node scripts/check-parity.js",
    "check:colors": "node scripts/check-colors.js",
    "check:treeshake": "node scripts/check-treeshake.js",
    "check:semantics": "node scripts/check-semantics.js",
    "check:choreographies": "node scripts/check-choreographies.js",
    "check:layers": "node scripts/check-layers.js",
    "check:motion-bounds": "node scripts/check-motion-bounds.js",
    "check:motion-collision": "node scripts/check-motion-collision.js",
    "check:variant-parity": "node scripts/check-variant-parity.js",
    "check:anatomy": "node scripts/check-anatomy.js && node scripts/check-anatomy-drift.js",
    "check:anatomy:drift": "node scripts/check-anatomy-drift.js",
    "check:path-quality": "node scripts/check-path-quality.js",
    "check:static-grid": "node scripts/check-static-grid.js",
    "check:fill-rule": "node scripts/check-fill-rule.js",
    "check:topology": "node scripts/check-topology.js",
    "check:corners": "node scripts/check-corners.js",
    "check:adjacency": "node scripts/check-adjacency.js",
    "check:ink-weight": "node scripts/check-ink-weight.js",
    "check:ink-weight:axes": "node scripts/check-ink-weight.js --axes",
    "check:grammar": "node scripts/check-grammar.js",
    "check:anim-ready": "node scripts/check-anim-ready.js",
    "check:fidelity": "node scripts/check-fidelity.js",
    "check:dry-coverage": "node scripts/check-dry-coverage.js",
    "check:docs-drift": "node scripts/check-docs-drift.js",
    "test": "vitest run",
    "verify": "node scripts/check-repo-contract.js && node scripts/build.js && node scripts/build-anatomy.js && tsup && tsc --noEmit && node scripts/check-parity.js && node scripts/check-colors.js && node scripts/check-treeshake.js && node scripts/check-semantics.js && node scripts/check-choreographies.js && node scripts/check-layers.js && node scripts/check-motion-bounds.js && node scripts/check-motion-collision.js && node scripts/check-variant-parity.js && node scripts/check-anatomy.js && node scripts/check-anatomy-drift.js && node scripts/check-path-quality.js && node scripts/check-static-grid.js && node scripts/check-fill-rule.js && node scripts/check-topology.js && node scripts/check-corners.js && node scripts/check-adjacency.js && node scripts/check-ink-weight.js && node scripts/check-ink-weight.js --axes && node scripts/check-grammar.js && node scripts/check-fidelity.js && node scripts/check-dry-coverage.js && node scripts/check-anim-ready.js && node scripts/check-docs-drift.js && vitest run"
  },
  "devDependencies": {
    "rollup": "^4.24.0",
    "svgo": "^3.3.2",
    "tsup": "8.3.6",
    "typescript": "5.7.3",
    "vitest": "2.1.8"
  },
  "license": "MIT",
  "keywords": [
    "icons",
    "svg",
    "design-system",
    "labpics",
    "outline",
    "filled",
    "animated-icons"
  ],
  "engines": {
    "node": ">=20",
    "pnpm": ">=9"
  }
}
